# Browser app variables
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project metadata for CLI workflows
SUPABASE_PROJECT_ID=

# Edge Functions secrets
# Keep these in Supabase secrets for deployed functions.
# Do not expose them in client-side hosting envs.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ENCRYPTION_KEY=
