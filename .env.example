# Browser app variables
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Local UI-only auth fallback for development only.
NEXT_PUBLIC_ENABLE_LOCAL_DEMO_AUTH=false

# Supabase project metadata for CLI workflows
SUPABASE_PROJECT_ID=

# Server / Edge Functions secrets
# Hosted Supabase injects SUPABASE_SERVICE_ROLE_KEY automatically for Edge Functions.
# Do not expose these values in client-side hosting envs.
SUPABASE_SERVICE_ROLE_KEY=
YCOACH_ENCRYPTION_KEY=
